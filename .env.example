# Public-facing URL used for metadata / Open Graph / structured data
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Secret token for the GET /api/enquiry admin endpoint
ENQUIRY_SECRET=change-me-in-production

# Telegram bot used by /api/book-appointment to notify the clinic of new
# appointment requests. Create a bot via @BotFather to get a token, then
# message the bot and call https://api.telegram.org/bot<TOKEN>/getUpdates
# to find your numeric chat id.
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
TELEGRAM_CHAT_ID=123456789
